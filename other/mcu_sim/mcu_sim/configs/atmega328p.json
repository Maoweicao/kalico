{
  "name": "atmega328p",
  "arch": "avr",
  "qemu_binary": "qemu-system-avr",
  "qemu_machine": "uno",
  "description": "Arduino Uno (ATmega328P, 16 MHz)",
  "clock_hz": 16000000,
  "flash_size": 32768,
  "ram_size": 2048,
  "eeprom_size": 1024,
  "uart_count": 1,
  "spi_count": 1,
  "i2c_count": 1,
  "peripherals": {
    "TIMER0": {"bits": 8, "address": "0x44"},
    "TIMER1": {"bits": 16, "address": "0x80"},
    "TIMER2": {"bits": 8, "address": "0xB0"},
    "USART0": {"address": "0xC0"}
  }
}
